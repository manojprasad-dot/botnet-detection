# ── Application ────────────────────────────────────────────────
DEBUG=False
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=*

# ── Database (PostgreSQL) ──────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://kovirx:kovirx@localhost:5432/kovirx
DB_PASSWORD=kovirx

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT Authentication ─────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-secure-random-key-in-production-deployments
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ── ML Detection Thresholds ────────────────────────────────────
ML_CONFIDENCE_CRITICAL=0.90
ML_CONFIDENCE_HIGH=0.75
ML_CONFIDENCE_MEDIUM=0.50

# ── Celery ─────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── SMTP (mock in dev) ─────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@kovirx.local

# ── First Super-Admin seed ─────────────────────────────────────
FIRST_SUPERADMIN_EMAIL=admin@kovirx.local
FIRST_SUPERADMIN_PASSWORD=KovirX@2024!
